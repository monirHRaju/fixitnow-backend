# FixItNow Backend - Environment Configuration
# Copy this file to .env and fill in your values

# Database connection string (PostgreSQL)
DATABASE_URL="postgresql://monirhraju@/fixitnow?host=/tmp&port=5434"

# JWT secret key (change this in production!)
JWT_SECRET="change-me-to-a-random-secret-in-production"

# Server port
PORT=3000

# SSLCommerz credentials (when you reach payments)
SSLC_STORE_ID=""
SSLC_STORE_PASSWORD=""
SSLC_SANDBOX=true

# SMTP (email notifications)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@fixitnow.com"