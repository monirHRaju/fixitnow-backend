{
  "compilerOptions": {
    /* Target & Module */
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],

    /* Output */
    "outDir": "./dist",
    "rootDir": "./src",

    /* Strictness */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Resolution */
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}