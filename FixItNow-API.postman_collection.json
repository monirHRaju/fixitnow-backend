    {
      "name": "Services",
      "item": [
        {
          "name": "GET /api/services (Public)",
          "description": "List active services with filters.\nQuery params: ?category=&search=&minPrice=&maxPrice=&location=&technician=&page=&limit=",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/services?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["services"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "category", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true },
                { "key": "minPrice", "value": "", "disabled": true },
                { "key": "maxPrice", "value": "", "disabled": true },
                { "key": "location", "value": "", "disabled": true },
                { "key": "technician", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "POST /api/technician/services (Technician)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{category_id}}\",\n  \"title\": \"Pipe Repair\",\n  \"description\": \"Fix leaking or burst pipes\",\n  \"price\": 150000,\n  \"durationMins\": 60\n}"
            },
            "url": {
              "raw": "{{base_url}}/technician/services",
              "host": ["{{base_url}}"],
              "path": ["technician", "services"]
            }
          }
        },
        {
          "name": "PUT /api/technician/services/:id (Technician)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Premium Pipe Repair\",\n  \"price\": 200000,\n  \"description\": \"Premium pipe repair service with warranty\",\n  \"durationMins\": 90,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/technician/services/{{service_id}}",
              "host": ["{{base_url}}"],
              "path": ["technician", "services", "{{service_id}}"]
            }
          }
        },
        {
          "name": "DELETE /api/technician/services/:id (Technician)",
          "description": "Soft-delete (sets isActive=false)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/technician/services/{{service_id}}",
              "host": ["{{base_url}}"],
              "path": ["technician", "services", "{{service_id}}"]
            }
          }
        },
        {
          "name": "GET /api/technician/services (Technician)",
          "description": "List own services. ?includeInactive=true to show inactive too",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/technician/services",
