        {
          "name": "PUT /api/technician/profile (Technician)",
          "description": "Update own technician profile. All fields optional — send only what to change.",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Expert plumber with 8 years experience\",\n  \"skills\": [\"Plumbing\", \"Electrical\"],\n  \"experience\": 8,\n  \"hourlyRate\": 50000,\n  \"location\": \"Gazipur, Dhaka\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/technician/profile",
              "host": ["{{base_url}}"],
              "path": ["technician", "profile"]
            }
          }
        },
        {
          "name": "PUT /api/technician/availability (Technician)",
          "description": "Replace all availability slots with the provided set.",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slots\": [\n    { \"dayOfWeek\": 1, \"startTime\": \"09:00\", \"endTime\": \"17:00\" },\n    { \"dayOfWeek\": 2, \"startTime\": \"09:00\", \"endTime\": \"17:00\" },\n    { \"dayOfWeek\": 3, \"startTime\": \"09:00\", \"endTime\": \"17:00\" },\n    { \"dayOfWeek\": 4, \"startTime\": \"09:00\", \"endTime\": \"17:00\" },\n    { \"dayOfWeek\": 5, \"startTime\": \"09:00\", \"endTime\": \"17:00\" },\n    { \"dayOfWeek\": 6, \"startTime\": \"10:00\", \"endTime\": \"14:00\" }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/technician/availability",
              "host": ["{{base_url}}"],
              "path": ["technician", "availability"]
            }
          }
        },
        {
          "name": "GET /api/technician/bookings (Technician)",
          "description": "View bookings assigned to the authenticated technician.\nQuery params: ?status=REQUESTED&page=&limit=",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/technician/bookings?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["technician", "bookings"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "PATCH /api/technician/bookings/:id (Technician)",
          "description": "Update booking status.\nAllowed transitions:\n  REQUESTED → ACCEPTED | DECLINED\n  ACCEPTED  → IN_PROGRESS\n  IN_PROGRESS → COMPLETED",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACCEPTED\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/technician/bookings/{{booking_id}}",
              "host": ["{{base_url}}"],
              "path": ["technician", "bookings", "{{booking_id}}"]
            }
          }
        }
